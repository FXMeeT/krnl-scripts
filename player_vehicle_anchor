local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 130, 0, 55)
frame.Position = UDim2.new(0, 10, 0, 10)
frame.BackgroundTransparency = 0.2
frame.Parent = gui

local button1 = Instance.new("TextButton")
button1.Size = UDim2.new(1, -4, 0, 24)
button1.Position = UDim2.new(0, 2, 0, 2)
button1.Text = "ANCHOR OFF"
button1.Parent = frame

local button2 = Instance.new("TextButton")
button2.Size = UDim2.new(1, -4, 0, 24)
button2.Position = UDim2.new(0, 2, 0, 28)
button2.Text = "A+V OFF"
button2.Parent = frame

-- Draggable frame (PC + Mobile)
local UIS = game:GetService("UserInputService")

local dragging = false
local dragStart
local startPos

frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and (
		input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch
	) then
		local delta = input.Position - dragStart

		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)
		local seat = humanoid.SeatPart
		if seat then
			local model = seat:FindFirstAncestorOfClass("Model")

			if model then
				for _, obj in ipairs(model:GetDescendants()) do
					if obj:IsA("BasePart") then
						obj.Anchored = false
					end
				end
			end
		end

		local root = character:FindFirstChild("HumanoidRootPart")
		if root then
			root.Anchored = false
		end
	end
end

button1.MouseButton1Click:Connect(function()
	setCharacterAnchor(not charAnchor)
end)

button2.MouseButton1Click:Connect(function()
	setVehicleAnchor(not vehicleAnchor)
end)
