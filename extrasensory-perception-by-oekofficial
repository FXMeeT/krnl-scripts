local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

-- ================= STATE =================
local enabled = true
local running = true

local settings = {
	AGL = true,
	SPEED = true,
	HEALTH = true,
	POS = true,
	DIR = true,
	BORDER = true,
}

local objects = {}

-- ================= CONTROLS =================
local textScaleInput = -4
local wireScaleInput = 1
local wireBoldInput = 1

local function clampWireSize(v)
	return math.max(1, v)
end

local function getTextScale()
	return math.clamp(1 + textScaleInput * 0.1, 0.25, 4)
end

local function getWireScale()
	return math.max(1, wireScaleInput)
end

local function getWireBold()
	return math.max(1, wireBoldInput)
end

-- ================= COLORS =================
local function getHealthColor(p)
	if p > 0.6 then
		return Color3.fromRGB(0,255,0)
	elseif p > 0.3 then
		return Color3.fromRGB(255,255,0)
	else
		return Color3.fromRGB(255,0,0)
	end
end

local COLOR_NAME = Color3.fromRGB(255,255,0)
local COLOR_SPEED = Color3.fromRGB(0,200,255)
local COLOR_DIR = Color3.fromRGB(180,180,255)
local COLOR_AGL = Color3.fromRGB(255,150,0)
local COLOR_POS = Color3.fromRGB(150,255,150)

-- ================= GUI =================
