-- ================= TOGGLES =================
local function makeToggle(name)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -10, 0, 25)
	btn.BackgroundColor3 = Color3.fromRGB(35,35,35)
	btn.Parent = content

	local function update()
		btn.Text = name .. ": " .. (settings[name] and "ON" or "OFF")
	end

	update()

	btn.MouseButton1Click:Connect(function()
		settings[name] = not settings[name]
		update()
	end)

	return update
end

makeToggle("AGL")
makeToggle("SPEED")
makeToggle("HEALTH")
makeToggle("POS")
makeToggle("DIR")
makeToggle("BORDER")

-- ================= GLOBAL =================
local globalBtn = Instance.new("TextButton")
globalBtn.Size = UDim2.new(1, -10, 0, 25)
globalBtn.BackgroundColor3 = Color3.fromRGB(50,50,50)
globalBtn.Text = "GLOBAL: ON"
globalBtn.Parent = content

globalBtn.MouseButton1Click:Connect(function()
	enabled = not enabled
	globalBtn.Text = "GLOBAL: " .. (enabled and "ON" or "OFF")
end)

-- ================= INPUTS =================
local textBox = Instance.new("TextBox")
textBox.Size = UDim2.new(1, -10, 0, 25)
textBox.PlaceholderText = "Text Scale (0 = normal)"
textBox.Text = "-4"
textBox.Parent = content

textBox.FocusLost:Connect(function()
	local v = tonumber(textBox.Text)
	if v then textScaleInput = v else textBox.Text = "-4" end
end)

local wireBox = Instance.new("TextBox")
wireBox.Size = UDim2.new(1, -10, 0, 25)
wireBox.PlaceholderText = "Wire Size (min 1)"
wireBox.Text = "1"
wireBox.Parent = content

wireBox.FocusLost:Connect(function()
	local v = tonumber(wireBox.Text)
	if v then wireScaleInput = math.max(1, v) else wireBox.Text = "1" end
end)

local boldBox = Instance.new("TextBox")
boldBox.Size = UDim2.new(1, -10, 0, 25)
boldBox.PlaceholderText = "Wire Boldness (min 1)"
boldBox.Text = "1"
boldBox.Parent = content

boldBox.FocusLost:Connect(function()
	local v = tonumber(boldBox.Text)
	if v then wireBoldInput = math.max(1, v) else boldBox.Text = "1" end
end)

-- ================= MINIMIZER FIX =================
local minimized = false
local fullSize = main.Size

minBtn.MouseButton1Click:Connect(function()
	minimized = not minimized

	if minimized then
		content.Visible = false
		main.Size = UDim2.new(0, 200, 0, 25)
	else
		content.Visible = true
		main.Size = fullSize
	end
end)

closeBtn.MouseButton1Click:Connect(function()
	running = false
	screenGui:Destroy()
	for _, d in pairs(objects) do
		if d.Box then d.Box:Destroy() end
		if d.Gui then d.Gui:Destroy() end
	end
end)

-- ================= PLAYER CLEANUP =================
Players.PlayerRemoving:Connect(function(plr)
	if objects[plr] then
		if objects[plr].Box then objects[plr].Box:Destroy() end
		if objects[plr].Gui then objects[plr].Gui:Destroy() end
		objects[plr] = nil
	end
end)

-- ================= CREATE =================
local function create(plr)
	local bb = Instance.new("BillboardGui")
	bb.Size = UDim2.new(0, 200, 0, 120)
	bb.AlwaysOnTop = true

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1,0,1,0)
	frame.BackgroundTransparency = 1
	frame.Parent = bb

	local function mk(y, color)
		local t = Instance.new("TextLabel")
		t.Size = UDim2.new(1,0,0,18)
		t.Position = UDim2.new(0,0,0,y)
		t.BackgroundTransparency = 1
		t.TextColor3 = color
		t.TextSize = 14
		t.Parent = frame
		return t
	end

	local ui = {
		Name = mk(0, COLOR_NAME),
		Health = mk(18, Color3.new(1,1,1)),
		Speed = mk(36, COLOR_SPEED),
		Dir = mk(54, COLOR_DIR),
		AGL = mk(72, COLOR_AGL),
		Pos = mk(90, COLOR_POS),
	}

	local box = Instance.new("SelectionBox")
	box.LineThickness = 0.02
	box.SurfaceTransparency = 1
	box.Color3 = Color3.fromRGB(255,255,255)
	box.Parent = workspace

	objects[plr] = {
		Gui = bb,
		Labels = ui,
		Box = box,
		WirePart = nil
	}

	bb.Parent = workspace
end

-- ================= UPDATE =================
RunService.RenderStepped:Connect(function()
	if not running or not enabled then return end

	local textScale = getTextScale()
	local wireScale = getWireScale()
	local bold = getWireBold()

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer then

			local char = plr.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			local hum = char and char:FindFirstChildOfClass("Humanoid")

			if not hrp or not hum then continue end
			if not objects[plr] then create(plr) end

			local obj = objects[plr]

			obj.Gui.Adornee = hrp
			obj.Gui.Enabled = true

			for _, lbl in pairs(obj.Labels) do
				lbl.TextSize = math.floor(14 * textScale)
			end

			local vel = hrp.AssemblyLinearVelocity.Magnitude
			local dir = math.deg(math.atan2(hrp.CFrame.LookVector.X, hrp.CFrame.LookVector.Z))

			obj.Labels.Name.Text = plr.Name
			obj.Labels.Health.Text = settings.HEALTH and ("HP: " .. math.floor(hum.Health)) or ""
			obj.Labels.Health.TextColor3 = getHealthColor(hum.Health / hum.MaxHealth)

			obj.Labels.Speed.Text = settings.SPEED and ("SPD: " .. math.floor(vel)) or ""
			obj.Labels.Dir.Text = settings.DIR and ("DIR: " .. math.floor(dir)) or ""
			obj.Labels.AGL.Text = settings.AGL and ("AGL: " .. math.floor(hrp.Position.Y)) or ""

			obj.Labels.Pos.Text = settings.POS and
				string.format("POS: %d,%d,%d",
					math.floor(hrp.Position.X),
					math.floor(hrp.Position.Y),
					math.floor(hrp.Position.Z)
				) or ""

			local box = obj.Box

			if settings.BORDER then
				local cf, size = char:GetBoundingBox()

				if not obj.WirePart then
					local p = Instance.new("Part")
					p.Anchored = true
					p.Transparency = 1
					p.CanCollide = false
					p.Parent = workspace
					obj.WirePart = p
				end

				local wp = obj.WirePart
				wp.Size = size * wireScale
				wp.CFrame = cf

				box.Adornee = wp
				box.Visible = true
				box.LineThickness = 0.02 * bold
			else
				box.Visible = false
			end
		end
	end
end)
