----------------------------------------------------
-- LOOP
----------------------------------------------------
RunService.RenderStepped:Connect(function()
	if not flying or not primary then return end

	local speed = tonumber(speedBox.Text) or 120
	local sens = tonumber(sensBox.Text) or 0.15

	local cf = cam.CFrame

	local look = Vector3.new(cf.LookVector.X,0,cf.LookVector.Z)
	local right = Vector3.new(cf.RightVector.X,0,cf.RightVector.Z)

	if look.Magnitude > 0 then look = look.Unit end
	if right.Magnitude > 0 then right = right.Unit end

	local move = Vector3.zero

	if input.fw then move += look end
	if input.bw then move -= look end
	if input.rt then move += right end
	if input.lt then move -= right end
	if input.up then move += Vector3.new(0,1,0) end
	if input.down then move -= Vector3.new(0,1,0) end

	if move.Magnitude > 0 then move = move.Unit end

	-- movement smoothing
	bv.Velocity = bv.Velocity:Lerp(move * speed, 0.25)

	------------------------------------------------
	-- ROTATION SENSITIVITY CONTROL (NEW)
	------------------------------------------------
	local targetCF = CFrame.lookAt(primary.Position, primary.Position + look)

	-- sensitivity controls how fast it follows camera
	bg.CFrame = bg.CFrame:Lerp(targetCF, math.clamp(sens, 0.01, 1))

	primary.AssemblyLinearVelocity *= 0.3
	primary.AssemblyAngularVelocity *= 0.3

	if noclip then
		for _,v in ipairs(vehicle:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end
end)
