----------------------------------------------------
-- VEHICLE
----------------------------------------------------
local vehicle, primary, bv, bg
local flying = false
local noclip = false

local function getVehicle()
	local c = plr.Character
	local h = c and c:FindFirstChildOfClass("Humanoid")
	local seat = h and h.SeatPart
	local model = seat and seat:FindFirstAncestorOfClass("Model")
	if not model then return nil, seat end
	return model, model.PrimaryPart or seat
end

local function clean(m)
	for _,v in ipairs(m:GetDescendants()) do
		if v:IsA("BodyVelocity") or v:IsA("BodyGyro") or v:IsA("LinearVelocity")
		or v:IsA("AngularVelocity") or v:IsA("VectorForce") then
			pcall(function() v:Destroy() end)
		end
	end
end

----------------------------------------------------
-- ENABLE / DISABLE
----------------------------------------------------
local function enable()
	vehicle, primary = getVehicle()
	if not vehicle or not primary then return end

	clean(vehicle)

	bv = Instance.new("BodyVelocity", primary)
	bv.MaxForce = Vector3.new(9e9,9e9,9e9)
	bv.P = 50000

	bg = Instance.new("BodyGyro", primary)
	bg.MaxTorque = Vector3.new(9e9,9e9,9e9)
	bg.P = 300000
	bg.D = 200

	for _,v in ipairs(vehicle:GetDescendants()) do
		if v:IsA("BasePart") then
			v.AssemblyLinearVelocity = Vector3.zero
			v.AssemblyAngularVelocity = Vector3.zero
			pcall(function() v:SetNetworkOwner(plr) end)
		end
	end

	flying = true
	flyBtn.Text = "FLY : ON"
end

local function disable()
	flying = false
	if bv then bv:Destroy() bv=nil end
	if bg then bg:Destroy() bg=nil end
	flyBtn.Text = "FLY : OFF"
end

